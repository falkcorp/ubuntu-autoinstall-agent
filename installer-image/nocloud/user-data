#
# Baked into a re-mastered Ubuntu Server ISO by make-ssh-ready-iso.sh so the
# LIVE installer session comes up SSH-ready with ZERO manual steps:
#   - openssh-server enabled,
#   - user `ubuntu-server` with a known password + operator SSH keys,
#   - NOPASSWD sudo (so `uaa install` can run every command as root over SSH
#     without needing root login enabled).
# This is a live-session cloud-config (NO `autoinstall:` key) — it configures
# the running installer environment; it does NOT trigger subiquity/curtin.

ssh_pwauth: true

users:
  - name: ubuntu-server
    lock_passwd: false
    shell: /bin/bash
    groups: [sudo, adm]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - "ssh-rsa  johnathan.falk@gmail.com"

# Throwaway live-session password (not a target secret). Override with
# UAA_LIVE_PASSWORD when running make-ssh-ready-iso.sh.
chpasswd:
  expire: false
  users:
    - {name: ubuntu-server, password: default, type: text}

runcmd:
  - [systemctl, enable, --now, ssh]
